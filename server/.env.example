# CEBIO Brasil Backend - Variáveis de Ambiente

# Server
PORT=8000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cebio_brasil

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=4h

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Logging
LOG_LEVEL=info
